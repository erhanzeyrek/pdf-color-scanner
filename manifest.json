{
  "manifest_version": 3,
  "name": "PDF Color Analytics",
  "version": "1.0.0",
  "description": "Pick colors from PDF documents and find all matching text elements.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open PDF Color Analytics"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer/viewer.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
